@import "tailwindcss";
@custom-variant dark (&:where(.dark, .dark *));

@utility no-scrollbar {
  &::-webkit-scrollbar {
    display: none;
  }
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* Hide page break indicators by default */
.page-break-indicator {
  display: none;
}

/* Screen: match print exactly - Paper sheet representation */
.resume-container {
  /* Width/minHeight should be controlled inline by ResumePreview's getStyles */
  margin: 0 auto !important;
  page-break-inside: avoid;
  background: white;
  box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
}

@media print {
  @page {
    margin: 0;
  }

  html, body {
    margin: 0 !important;
    padding: 0 !important;
    height: auto !important;
    overflow: visible !important;
    background: white !important;
  }

  /* Hide everything except the resume content (use header.sticky to target only Navbar, not resume <header>) */
  header.sticky, footer, nav, aside, button, .no-print, .page-break-indicator {
    display: none !important;
  }

  /* Match screen exactly - A4 sheet is 210mm */
  .resume-container {
    width: 210mm !important;
    max-width: 210mm !important;
    margin: 0 !important;
    padding: inherit !important;
    box-shadow: none !important;
    page-break-inside: avoid;
    overflow: visible !important;
  }

  .resume-page {
    page-break-after: always;
    page-break-inside: avoid;
    min-height: auto !important;
  }

  * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
    color-adjust: exact !important;
  }
}

