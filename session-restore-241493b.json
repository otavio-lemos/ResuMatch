nction getAtsParserSkill(language: string = 'pt'): string {\n61:   const content = readSkillFile('ats-parser', language);\n62:   const section = extractSection(content, '########## PPPAAARRRSSSIIINNNGGG', '########## FIM PPPAAARRRSSSIIINNNGGG');\n63: \n64:   if (!section) {\n65:     console.warn(`[Skill] ats-parser: PPPAAARRRSSSIIINNNGGG section not found for language ${language}`);\n66:     return language === 'en'\n67:       ? 'You are a resume data extractor.'\n68:       : 'Você é um extrator de dados de currículos.';\n69:   }\n70: \n71:   return section;\n72: }\n73: \n74: /**\n75:  * Get ATS Analyzer Skill (Phase 2 - Audit/ATS)\n76:  * Extracts from AAAUUUDDDIIITTTOOORRRIIIAAA section\n77:  */\n78: export function getAtsAnalyzerSkill(language: string = 'pt'): string {\n79:   const content = readSkillFile('ats-auditor', language);\n80:   const section = extractSection(content, '########## AAAUUUDDDIIITTTOOORRRIIIAAA', '########## FIM AAAUUUDDDIIITTTOOORRRIIIAAA');\n81: \n82:   if (!section) {\n83:     console.warn(`[Skill] ats-auditor: AAAUUUDDDIIITTTOOORRRIIIAAA section not found for language ${language}`);\n84:     return language === 'en'\n85:       ? 'You are an ATS specialist.'\n86:       : 'Você é um especialista em ATS.';\n87:   }\n88: \n89:   return section;\n90: }\n91: \n92: /**\n93:  * Get ATS Summary Skill (for summary generation)\n94:  * Extracts from SSSUMMMMAAARRRYYY section\n95:  */\n96: export function getAtsSummarySkill(language: string = 'pt'): string {\n97:   const content = readSkillFile('resume-editor', language);\n98:   const section = extractSection(content, '########## SSSUMMMMAAARRRYYY', '########## FIM SSSUMMMMAAARRRYYY');\n99: \n100:   if (!section) {\n101:     console.warn(`[Skill] resume-editor: SSSUMMMMAAARRRYYY section not found for language ${language}`);\n102:     return language === 'en'\n103:       ? 'You are a professional resume writer.'\n104:       : 'Você é um redator profissional de currículos.';\n105:   }\n106: \n107:   re