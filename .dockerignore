# .dockerignore
node_modules
.next
.git

# Variáveis de ambiente locais (nunca na imagem!)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ferramentas de deploy externas
.vercel

# NOTA: NÃO excluir *.md globalmente!
# O .agent/skills/ contém arquivos SKILL.md lidos em runtime pelo get-skill.ts
# Excluir apenas os .md de documentação na raiz do projeto:
README.md
DEVELOPMENT.md
CVLLM.md
VALIDATION_REPORT.md

# Dados locais e artefatos de dev
data/
LIXO/

# TypeScript build info (grande, não necessário)
tsconfig.tsbuildinfo
