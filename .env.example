# ============================================================
# ResuMatch — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores:
#   cp .env.example .env.local
#
# O docker-compose.yml lê automaticamente o GEMINI_API_KEY
# do ambiente do host (ou do .env.local se exportado).
# ============================================================

# ── Provedor padrão: Google Gemini ───────────────────────────
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui

# ── Provedor alternativo: OpenAI ─────────────────────────────
# (opcional — configure nas Configurações da app)
# OPENAI_API_KEY=sk-...

# ── Provedor local: Ollama ────────────────────────────────────
# (sem chave API — configure o endereço nas Configurações da app)
# Quando usar Docker, a app detecta DOCKER_CONTAINER=true
# e usa automaticamente host.docker.internal:11434

# Telemetry
NEXT_TELEMETRY_DISABLED=1
FIREBASE_CLI_TELEMETRY=0
DO_NOT_TRACK=1
VERCEL_TELEMETRY_DISABLED=1
